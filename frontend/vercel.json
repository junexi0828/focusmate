{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/(.*)",
      "destination": "https://api.eieconcierge.com/api/v1/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://api.eieconcierge.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
